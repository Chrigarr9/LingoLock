  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.0",
    "jest": "^30.2.0",
    "patch-package": "^8.0.1",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2"
  },
  "private": true,
  "description": "iOS vocabulary learning app with Lock Screen integration, Shortcuts automation, and timed notifications",
  "repository": {
    "type": "git",
