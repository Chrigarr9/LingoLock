{
  "name": "lingolock",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "rm -rf dist 2>/dev/null; npx expo export --platform web && npx serve dist -s",
    "web:dev": "expo start --web",
    "build:content": "npx tsx scripts/build-content.ts",
    "build:web": "npx expo export --platform web",
    "test": "jest",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "expo": "~55.0.0",
    "expo-audio": "~55.0.9",
    "expo-background-fetch": "~13.0.5",
    "expo-build-properties": "^55.0.10",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.10",
    "expo-document-picker": "~55.0.9",
    "expo-file-system": "~55.0.11",
    "expo-linking": "~55.0.7",
    "expo-notifications": "~55.0.10",
    "expo-router": "~55.0.3",
    "expo-sqlite": "~55.0.11",
    "expo-task-manager": "~12.0.5",
    "expo-widgets": "^55.0.5",
    "jszip": "^3.10.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "^0.83.2",
    "react-native-mmkv": "^4.1.2",
    "react-native-nitro-modules": "^0.34.1",
    "react-native-paper": "^5.15.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "react-native-zip-archive": "^7.0.2",
    "sql.js": "^1.14.1",
    "ts-fsrs": "^5.2.3"
