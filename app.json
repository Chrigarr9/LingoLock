{
  "expo": {
    "name": "LingoLock",
    "slug": "lingolock",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "lingolock",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lingolock.app",
      "entitlements": {
        "com.apple.security.application-groups": ["group.com.lingolock.app"]
      },
      "infoPlist": {
        "UIBackgroundModes": ["fetch"],
        "NSUserNotificationsUsageDescription": "LingoLock uses notifications to remind you to practice vocabulary at regular intervals.",
        "LSApplicationQueriesSchemes": [
          "instagram", "twitter", "fb", "tiktok", "youtube",
          "reddit", "linkedin", "whatsapp", "telegram", "discord",
          "snapchat", "pinterest", "spotify", "netflix", "googlegmail",
          "googlechrome", "maps", "sms", "calshow"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.lingolock.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png",
      "name": "LingoLock",
      "shortName": "LingoLock",
      "description": "Vocabulary learning with spaced repetition",
      "themeColor": "#5B8EC4",
      "backgroundColor": "#EEF3F9",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-audio",
      "expo-notifications",
      [
        "expo-widgets",
        {
          "ios": {
            "widgets": [
              {
                "name": "VocabularyWidget",
                "displayName": "LingoLock Practice",
                "description": "Practice vocabulary directly from your Home Screen or Lock Screen",
                "families": [
                  "systemSmall",
                  "systemMedium",
                  "accessoryRectangular"
                ]
              }
            ]
          }
        }
      ],
      "expo-sqlite",
      "react-native-mmkv",
      "expo-background-fetch",
      "expo-task-manager"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
