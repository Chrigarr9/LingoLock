{
  "expo": {
    "name": "LingoLock",
    "slug": "lingolock",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "lingolock",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lingolock.app",
      "infoPlist": {
        "NSNotificationAlwaysDisplayPermission": true,
        "NSUserNotificationsUsageDescription": "LingoLock uses notifications to remind you to practice vocabulary at regular intervals."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.lingolock.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png",
      "name": "LingoLock",
      "shortName": "LingoLock",
      "description": "Vocabulary learning with spaced repetition",
      "themeColor": "#5B8EC4",
      "backgroundColor": "#EEF3F9",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-audio",
      "expo-notifications",
      [
        "expo-widgets",
        {
          "ios": {
            "widgets": [
              {
                "name": "VocabularyWidget",
                "displayName": "LingoLock Practice",
                "description": "Practice vocabulary directly from your Home Screen or Lock Screen",
                "families": ["systemSmall", "systemMedium", "accessoryRectangular"]
              }
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
