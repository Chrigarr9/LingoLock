{
  "expo": {
    "name": "LingoLock",
    "slug": "lingolock",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "lingolock",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "icon": {
        "light": "./assets/icon.png",
        "dark": "./assets/icon-dark.png",
        "tinted": "./assets/icon-tinted.png"
      },
      "supportsTablet": true,
      "bundleIdentifier": "com.lingolock.app",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.lingolock.app"
        ]
      },
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch"
        ],
        "NSUserNotificationsUsageDescription": "LingoLock uses notifications to remind you to practice vocabulary at regular intervals.",
        "LSApplicationQueriesSchemes": [
          "instagram",
          "tiktok",
          "fb",
          "twitter",
          "snapchat",
          "barcelona",
          "bereal",
          "pinterest",
          "reddit",
          "linkedin",
          "tumblr",
          "whatsapp",
          "telegram",
          "discord",
          "sgnl",
          "fb-messenger",
          "youtube",
          "netflix",
          "twitch",
          "disneyplus",
          "aiv",
          "spotify",
          "music",
          "soundcloud",
          "googlechrome",
          "x-safari-https",
          "googlegmail",
          "maps",
          "photos-redirect",
          "sms",
          "message",
          "mobilenotes",
          "calshow",
          "x-apple-reminder",
          "app-settings",
          "robloxmobile",
          "clashroyale"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.lingolock.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png",
      "name": "LingoLock",
      "shortName": "LingoLock",
      "description": "Vocabulary learning with spaced repetition",
      "themeColor": "#5B8EC4",
      "backgroundColor": "#EEF3F9",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ],
      "expo-router",
      "expo-dev-client",
      "expo-audio",
      "expo-notifications",
      [
        "expo-widgets",
        {
          "widgets": [
            {
              "name": "VocabularyWidget",
              "displayName": "LingoLock Practice",
              "description": "Practice vocabulary directly from your Home Screen or Lock Screen",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium",
                "systemLarge",
                "accessoryRectangular"
              ]
            }
          ]
        }
      ],
      "expo-sqlite",
      "expo-background-fetch",
      "expo-task-manager",
      "./plugins/withWidgetNotificationSync",
      "./plugins/withAppIntents"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "ExpoWidgetsTarget",
                  "bundleIdentifier": "com.lingolock.app.ExpoWidgetsTarget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.lingolock.app"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "8c181cf9-f9b9-4913-bdd3-e30ca2f48e9b"
      }
    }
  }
}
